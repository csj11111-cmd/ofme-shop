VITE_API_BASE_URL=/api

# Cloudinary Upload Widget (필수 2개 + 선택 1개)
# 1) Cloudinary Dashboard > Home 에서 Cloud name 복사
# 2) Settings > Upload > Add upload preset (Signing Mode: Unsigned)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_FOLDER=ofme-products

# PortOne V2 결제 (Vercel 배포 시 필수)
VITE_PORTONE_V2_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
